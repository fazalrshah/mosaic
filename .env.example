# Mosaic configuration (copy to .env or export). All optional — sane defaults shown.
MILVUS_HOST=localhost
MILVUS_PORT=19530

EMBED_MODEL=BAAI/bge-m3
EMBED_DEVICE=          # blank = auto-detect (mps / cuda / cpu)
EMBED_DIM=1024         # must match EMBED_MODEL

CHUNK_TOKENS=800       # target tokens per chunk (keep 500-1000)
EMBED_BATCH=16
ENABLE_BM25=1          # 1 = dense + native BM25 (Milvus 2.5+); 0 = dense only
